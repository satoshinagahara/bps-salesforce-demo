<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>63.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>サプライヤー認証一覧</masterLabel>
    <description>ISO9001等のサプライヤー認証を一覧表示・追加・編集・削除するカードビュー。</description>
    <targets>
        <target>lightning__AppPage</target>
        <target>lightning__HomePage</target>
        <target>lightning__RecordPage</target>
        <target>lightningCommunity__Page</target>
        <target>lightningCommunity__Default</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightning__AppPage,lightning__HomePage">
            <property name="accountId" type="String" label="サプライヤーAccount Id (デモ用)"/>
        </targetConfig>
        <targetConfig targets="lightning__RecordPage">
            <property name="accountId" type="String" label="サプライヤーAccount Id (デモ用)"/>
            <objects>
                <object>Account</object>
            </objects>
        </targetConfig>
        <targetConfig targets="lightningCommunity__Default">
            <property name="accountId" type="String" label="サプライヤーAccount Id"/>
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>
