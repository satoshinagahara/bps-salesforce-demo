<?xml version="1.0" encoding="UTF-8"?>
<PathAssistant xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>true</active>
    <entityName>Product_Initiative__c</entityName>
    <fieldName>Status__c</fieldName>
    <masterLabel>製品施策</masterLabel>
    <pathAssistantSteps>
        <fieldNames>Title__c</fieldNames>
        <fieldNames>Product__c</fieldNames>
        <fieldNames>What_Description__c</fieldNames>
        <fieldNames>Why_Rationale__c</fieldNames>
        <fieldNames>Priority__c</fieldNames>
        <info>&lt;p&gt;&lt;strong&gt;施策のアイデアを起案した段階です。&lt;/strong&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;What（何をやるか）とWhy（なぜやるか）を明確に記載してください&lt;/li&gt;&lt;li&gt;対象製品と優先度を設定してください&lt;/li&gt;&lt;li&gt;ニーズ分析ダッシュボードから関連ニーズカードが紐付いているか確認してください&lt;/li&gt;&lt;li&gt;紐付けニーズが少ない場合は「関連ニーズ候補」パネルからAI分析で追加検討してください&lt;/li&gt;&lt;/ul&gt;</info>
        <picklistValueName>起案</picklistValueName>
    </pathAssistantSteps>
    <pathAssistantSteps>
        <fieldNames>Target_Customer__c</fieldNames>
        <fieldNames>Target_Industry__c</fieldNames>
        <fieldNames>Estimated_Revenue__c</fieldNames>
        <fieldNames>Estimated_Cost__c</fieldNames>
        <fieldNames>Approach__c</fieldNames>
        <info>&lt;p&gt;&lt;strong&gt;施策の事業性・技術的妥当性を評価する段階です。&lt;/strong&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;ターゲット顧客像・業種を具体化してください&lt;/li&gt;&lt;li&gt;見込み売上とコストを試算し、投資対効果を明らかにしてください&lt;/li&gt;&lt;li&gt;アプローチ（How）を記載し、実現可能性を検証してください&lt;/li&gt;&lt;li&gt;関連する設計開発プロジェクトの有無を確認してください&lt;/li&gt;&lt;/ul&gt;</info>
        <picklistValueName>評価中</picklistValueName>
    </pathAssistantSteps>
    <pathAssistantSteps>
        <fieldNames>Decision_Note__c</fieldNames>
        <fieldNames>Target_Start__c</fieldNames>
        <fieldNames>Target_Release__c</fieldNames>
        <info>&lt;p&gt;&lt;strong&gt;施策の実行が承認されました。&lt;/strong&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;承認の判断理由を記録してください&lt;/li&gt;&lt;li&gt;着手目標日とリリース目標日を設定してください&lt;/li&gt;&lt;li&gt;設計開発プロジェクト（Design Project）を作成し、この施策に紐付けてください&lt;/li&gt;&lt;li&gt;必要なリソース・体制を確保してください&lt;/li&gt;&lt;/ul&gt;</info>
        <picklistValueName>承認</picklistValueName>
    </pathAssistantSteps>
    <pathAssistantSteps>
        <fieldNames>Target_Start__c</fieldNames>
        <fieldNames>Target_Release__c</fieldNames>
        <fieldNames>Approach__c</fieldNames>
        <info>&lt;p&gt;&lt;strong&gt;施策が実行フェーズに入っています。&lt;/strong&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;設計開発プロジェクトの進捗を定期的に確認してください&lt;/li&gt;&lt;li&gt;スケジュールに変更がある場合は目標日を更新してください&lt;/li&gt;&lt;li&gt;紐付けニーズカードの鮮度変化に注意してください（顧客の関心が薄れていないか）&lt;/li&gt;&lt;li&gt;商談ページの「製品ロードマップ」に本施策が表示されています&lt;/li&gt;&lt;/ul&gt;</info>
        <picklistValueName>実行中</picklistValueName>
    </pathAssistantSteps>
    <pathAssistantSteps>
        <fieldNames>Decision_Note__c</fieldNames>
        <fieldNames>Target_Release__c</fieldNames>
        <info>&lt;p&gt;&lt;strong&gt;施策が完了しました。&lt;/strong&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;成果・結果を判断理由に記録してください&lt;/li&gt;&lt;li&gt;当初の見込み売上・コストとの差異を振り返ってください&lt;/li&gt;&lt;li&gt;紐付けニーズが充足されたか確認してください&lt;/li&gt;&lt;/ul&gt;</info>
        <picklistValueName>完了</picklistValueName>
    </pathAssistantSteps>
    <pathAssistantSteps>
        <fieldNames>Decision_Note__c</fieldNames>
        <info>&lt;p&gt;&lt;strong&gt;施策が不採用となりました。&lt;/strong&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;不採用の判断理由を必ず記録してください（将来の参考になります）&lt;/li&gt;&lt;li&gt;紐付けニーズは消し込まれません。別の施策で再度検討される可能性があります&lt;/li&gt;&lt;/ul&gt;</info>
        <picklistValueName>不採用</picklistValueName>
    </pathAssistantSteps>
    <recordTypeName>__MASTER__</recordTypeName>
</PathAssistant>
