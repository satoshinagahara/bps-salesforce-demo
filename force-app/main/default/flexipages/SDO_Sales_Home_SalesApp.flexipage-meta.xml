<?xml version="1.0" encoding="UTF-8"?>
<FlexiPage xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>SDO Homepage - Sales App Default</description>
    <flexiPageRegions>
        <itemInstances>
            <componentInstance>
                <componentInstanceProperties>
                    <name>decorate</name>
                    <value>true</value>
                </componentInstanceProperties>
                <componentInstanceProperties>
                    <name>richTextValue</name>
                    <value>&lt;p&gt;&lt;strong style=&quot;color: rgb(0, 0, 0); font-size: 18px;&quot;&gt;# BPS Corporation デモ環境サマリー&lt;/strong&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;作成者：snagahara@salesforce.com&lt;/p&gt;&lt;p&gt;最終更新日：2026/03/14&lt;/p&gt;&lt;p&gt;※実装詳細は&lt;a href=&quot;https://trailsignup-61aa736aacb04f.my.salesforce.com/sfc/p/Ie000000IdKv/a/Ie000000HZj3/gN.itG52k8LUEceHKnGxobKPppjoZBoB6.9ZhzCd3cE&quot; rel=&quot;noopener noreferrer&quot; target=&quot;_blank&quot;&gt;こちらのファイル&lt;/a&gt;（.mdファイル）に記載&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;strong style=&quot;font-size: 14px;&quot;&gt;&lt;u&gt;## 1. BOM管理&lt;/u&gt;&lt;/strong&gt;&lt;/p&gt;&lt;p&gt;Product2→BOM_Header→BOM_Line→BOM_SubComponent→BOM_Part の4階層部品表。ツリー表示、M-BOM/E-BOM比較。&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;strong style=&quot;font-size: 14px;&quot;&gt;&lt;u&gt;## 2. サプライチェーン可視化&lt;/u&gt;&lt;/strong&gt;&lt;/p&gt;&lt;p&gt;自社4工場＋サプライヤー11拠点の地図表示。災害シミュレーション（南海トラフ等）。サプライヤー依存度グラフ。BOM逆引きで供給側からの需要見通し。&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;strong style=&quot;font-size: 14px;&quot;&gt;&lt;u&gt;## 3. 品質管理（8Dプロセス）&lt;/u&gt;&lt;/strong&gt;&lt;/p&gt;&lt;p&gt;Case→Corrective_Action（8Dフェーズ）→Supplier_Investigation。AI現状サマリー、水平展開分析、ナレッジ自動生成。全社品質KPIパネル。&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;strong style=&quot;font-size: 14px;&quot;&gt;&lt;u&gt;## 4. 調達管理（RFQ）&lt;/u&gt;&lt;/strong&gt;&lt;/p&gt;&lt;p&gt;RFQ→RFQ_Quote の見積依頼・回答フロー。見積比較、サプライヤー別RFQ履歴。全社調達ステータスボード。&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;strong style=&quot;font-size: 14px;&quot;&gt;&lt;u&gt;## 5. サプライヤー品質評価&lt;/u&gt;&lt;/strong&gt;&lt;/p&gt;&lt;p&gt;Supplier_Audit（監査）、Supplier_Certification（認証）、スコアカード。監査16件・認証21件のデモデータ。&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;strong style=&quot;font-size: 14px;&quot;&gt;&lt;u&gt;## 6. 設計開発管理&lt;/u&gt;&lt;/strong&gt;&lt;/p&gt;&lt;p&gt;Design_Project→Design_Phase のフェーズ管理。ガントチャート、BOM比較、関連ナレッジパネル（Knowledge__kav連携）。&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;strong style=&quot;font-size: 14px;&quot;&gt;&lt;u&gt;## 7. Manufacturing Cloud 2.0（営業需要管理）&lt;/u&gt;&lt;/strong&gt;&lt;/p&gt;&lt;p&gt;Design Win商談→Revenue_Forecast（品目×四半期予測）→Sales_Agreement→Schedule（月別計画/実績）の一気通貫。受注予測グリッド編集、DW→販売契約変換、需要乖離What-ifシミュレーション（AI洞察付き）、全社営業需要ダッシュボード。&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;strong style=&quot;font-size: 14px;&quot;&gt;&lt;u&gt;## 8. ニーズカード（市場インテリジェンス）&lt;/u&gt;&lt;/strong&gt;&lt;/p&gt;&lt;p&gt;Meeting_Record→Needs_Card→Needs_Card_Source。面談記録からAIがニーズを構造化抽出。5軸分析ダッシュボード（セグメント切替＋AIインライン分析）。鮮度管理。&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;strong style=&quot;font-size: 14px;&quot;&gt;&lt;u&gt;## 9. Agentforce（従業員エージェント）&lt;/u&gt;&lt;/strong&gt;&lt;/p&gt;&lt;p&gt;5トピック: 取引先分析 / 水平展開分析 / ナレッジ作成 / BOM分析 / サプライヤー影響分析。Apex→ConnectApi→Prompt Templateの1アクション統合パターン。&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;strong style=&quot;font-size: 14px;&quot;&gt;&lt;u&gt;## 10. その他&lt;/u&gt;&lt;/strong&gt;&lt;/p&gt;&lt;p&gt;顧客報告メール生成（Flow+Prompt Template）、工数トラッカー、Salesforceクイズ、電卓、汎用テーブルエディタ。&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;strong style=&quot;font-size: 14px;&quot;&gt;&lt;u&gt;## デモデータ&lt;/u&gt;&lt;/strong&gt;&lt;/p&gt;&lt;p&gt;製品15品目、サプライヤー6社（責任者19名）、BOM 13件、RFQ 8件、面談14件、ニーズカード66件。Design Win商談2件（丸菱商事/ノヴァテック）＋販売契約（ノヴァテック ATLAS）＋通常商談多数。&lt;/p&gt;</value>
                </componentInstanceProperties>
