# mlx-lm OpenAI-compatible server
MLX_BASE_URL=http://127.0.0.1:8080/v1
MLX_MODEL=mlx-community/gemma-4-26b-a4b-it-4bit
# ※ 軽量版: mlx-community/gemma-4-e4b-it-4bit

# Salesforce (公式 @salesforce/mcp が sf CLI 認証を参照。sf-config.json から target-org を解決)
# SF_CONFIG_PATH=../sf-config.json

# Google Workspace (Calendar / Gmail)
GOOGLE_OAUTH_CREDENTIALS=config/tokens/google_credentials.json
GOOGLE_OAUTH_TOKEN=config/tokens/google_token.json

# User profile (config/user_profile.yaml)
# USER_PROFILE_PATH=config/user_profile.yaml

# Agent settings
AGENT_MAX_TURNS=8
AGENT_TIMEOUT_SEC=120
